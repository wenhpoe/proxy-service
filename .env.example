PROXY_ADMIN_PASSWORD=change-me
PROXY_ADMIN_SESSION_SECRET=change-me-to-a-long-random-string
PROXY_ADMIN_SESSION_TTL_SEC=43200
# Activation code TTL (seconds). Used when /v1/admin/codes has no ttlSec.
# 激活码默认有效期固定为 1 天（服务端不再提供该项配置）
# Default is session cookie (expires when browser closes). To persist:
# PROXY_ADMIN_COOKIE_PERSIST=1
# If you serve Proxy Service over HTTPS, set:
# PROXY_ADMIN_COOKIE_SECURE=1
